# ============================================================
# InternHub — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# -------------------------------------------------------
# Tool 1 — Internship Tracker
# -------------------------------------------------------

# Gmail address that sends the notification emails
EMAIL_SENDER=your.gmail@gmail.com

# Gmail App Password (NOT your account password).
# Generate one at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account.
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email address that receives the notifications (can be the same as sender)
EMAIL_RECIPIENT=your.email@gmail.com

# -------------------------------------------------------
# Tool 2 — LinkedIn Networking Pipeline
# -------------------------------------------------------

# LinkedIn login credentials
LINKEDIN_EMAIL=your.linkedin@email.com
LINKEDIN_PASSWORD=your_linkedin_password

# Anthropic API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
