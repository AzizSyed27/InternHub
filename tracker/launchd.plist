<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  tracker/launchd.plist
  =====================
  macOS launchd job that fires tracker/main.py every 5 minutes.

  SETUP (on the Mac mini):
  -------------------------
  1. Replace YOUR_PYTHON_PATH with the output of: which python3
     Example: /usr/local/bin/python3
     If using a venv: /Users/YOUR_USERNAME/internhub/.venv/bin/python

  2. Replace YOUR_REPO_PATH with the absolute path to the repo root.
     Example: /Users/YOUR_USERNAME/internhub

  3. Copy this file to ~/Library/LaunchAgents/:
       cp tracker/launchd.plist ~/Library/LaunchAgents/com.internhub.tracker.plist

  4. Load it:
       launchctl load ~/Library/LaunchAgents/com.internhub.tracker.plist

  5. To unload (stop tracking):
       launchctl unload ~/Library/LaunchAgents/com.internhub.tracker.plist

  6. Logs are written to tracker/tracker.log and tracker/tracker_error.log
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.internhub.tracker</string>

    <key>ProgramArguments</key>
    <array>
        <string>YOUR_PYTHON_PATH</string>
        <string>YOUR_REPO_PATH/tracker/main.py</string>
    </array>

    <!-- Fire every 300 seconds (5 minutes) -->
    <key>StartInterval</key>
    <integer>300</integer>

    <!-- Also run immediately when launchd loads the job -->
    <key>RunAtLoad</key>
    <true/>

    <!-- Working directory — main.py uses relative paths for seen_jobs.json -->
    <key>WorkingDirectory</key>
    <string>YOUR_REPO_PATH</string>

    <!-- Log stdout and stderr to files in the repo -->
    <key>StandardOutPath</key>
    <string>YOUR_REPO_PATH/tracker/tracker.log</string>

    <key>StandardErrorPath</key>
    <string>YOUR_REPO_PATH/tracker/tracker_error.log</string>
</dict>
</plist>
